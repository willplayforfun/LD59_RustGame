{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo run",
            "type": "shell",
            "command": "cargo run",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo build",
            "type": "shell",
            "command": "cargo build",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo build --release",
            "type": "shell",
            "command": "cargo build --release",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo test",
            "type": "shell",
            "command": "cargo test",
            "group": { "kind": "test", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo check",
            "type": "shell",
            "command": "cargo check",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo clippy",
            "type": "shell",
            "command": "cargo clippy",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "build web (windows)",
            "type": "shell",
            "command": ".\\web\\scripts\\build_web.ps1",
            "windows": { "command": ".\\web\\scripts\\build_web.ps1" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "build web (linux/mac)",
            "type": "shell",
            "command": "bash web/scripts/build_web.sh",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$rustc"
        },
        {
            "label": "serve web",
            "type": "shell",
            "command": "cargo install basic-http-server 2>$null; basic-http-server web/Survey_web",
            "windows": { "command": "cargo install basic-http-server 2>$null; basic-http-server web/Survey_web" },
            "linux": { "command": "cargo install basic-http-server 2>/dev/null; basic-http-server web/Survey_web" },
            "osx": { "command": "cargo install basic-http-server 2>/dev/null; basic-http-server web/Survey_web" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        }
    ]
}
